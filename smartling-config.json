{
    "locales": [
         {
             "smartling" : "fr-FR",
             "application" : "fr_FR"
         },
         {
             "smartling" : "de-DE",
             "application" : "de_DE"

         },
         {
             "smartling" : "en-US",
             "application" : "en_US"

         }
     ],

     "resourceSets": [
         {
            "type": "json",
            "pathRegex": "en\\/.*\\.json",
            "translationPathExpression": "{original_path}/strings_${locale}",
            "translationCommitMessage": "Translated ${originalFile.fullName} to ${locale}"
         }
     ]
}
